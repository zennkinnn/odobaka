---
type Props = {
  currentPage: number;
  totalPages: number;
  basePath?: string;
};

const { currentPage, totalPages, basePath = '/news/' } = Astro.props;
const getPageHref = (page: number) => (page === 1 ? basePath : `${basePath}page/${page}/`);
const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="News pagination">
      {currentPage > 1 && (
        <a class="pagination-link" href={getPageHref(currentPage - 1)}>
          Prev
        </a>
      )}
      {pages.map((page) => (
        <a
          class:list={['pagination-link', page === currentPage && 'pagination-current']}
          href={getPageHref(page)}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      ))}
      {currentPage < totalPages && (
        <a class="pagination-link" href={getPageHref(currentPage + 1)}>
          Next
        </a>
      )}
    </nav>
  )
}
