---
import BaseLayout from '@layouts/BaseLayout.astro';
import type { Update } from '@data/mock';
import { getSiteSettings, getUpdates } from '@lib/cms';

type Props = {
  update: Update;
};

export async function getStaticPaths() {
  const updates = await getUpdates();
  return updates.map((update) => ({
    params: { slug: update.id },
    props: { update }
  }));
}

const site = await getSiteSettings();
const { update } = Astro.props as Props;
---

<BaseLayout site={site} title={`${update.title} | ${site.name}`} description={update.summary}>
  <article class="article">
    <div class="article-meta">
      <time datetime={update.date}>{update.date}</time>
      <span>{update.categoryLabel}</span>
    </div>
    <h1>{update.title}</h1>
    <p class="article-lead">{update.summary}</p>
    {update.imageUrl && <img class="article-image" src={update.imageUrl} alt={update.imageAlt ?? update.title} />}
    {update.bodyHtml ? <div class="article-body" set:html={update.bodyHtml} /> : <p>{update.body}</p>}
    <a class="text-link" href="/">ホームへ戻る</a>
  </article>
</BaseLayout>
